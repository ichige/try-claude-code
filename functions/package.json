{
  "name": "functions",
  "version": "0.0.1",
  "description": "Azure Functions v4",
  "author": "T.Ichige <magromoe@gmail.com>",
  "type": "module",
  "private": true,
  "main": "dist/src/{index.js,routes/*.js}",
  "scripts": {
    "build": "node build.js",
    "typecheck": "tsc",
    "dev": "func start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@azure/cosmos": "^4.9.3",
    "@azure/functions": "^4.14.0",
    "@azure/identity": "^4.13.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": "^22 || ^24"
  }
}
