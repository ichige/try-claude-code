# 正常作成（id 省略 → UUID 自動発行、pk 省略 → コンテナ名から導出）
POST http://localhost:7071/api/create-item/Consignors
Content-Type: application/json
Accept: application/json

{
  "code": "test-0034",
  "name": "もっふ",
  "invoiceNumber": "T30304",
  "paymentRate": 80,
  "note": "備考欄"
}

###

# 正常作成（id・pk 明示）
POST http://localhost:7071/api/create-item/Consignors
Content-Type: application/json
Accept: application/json

{
  "id": "6e0b379b-5998-4e91-ba20-443e861b5b8a",
  "pk": "pk-consignors",
  "code": "test-0022",
  "name": "お名前です",
  "invoiceNumber": "T30303",
  "paymentRate": 80,
  "note": "備考欄"
}

###

# 400（無効な UUID）
POST http://localhost:7071/api/create-item/Consignors
Content-Type: application/json
Accept: application/json

{
  "id": "not-a-uuid",
  "code": "test-0022",
  "name": "お名前です"
}

###
