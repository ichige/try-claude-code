# 正常バルク削除
POST http://localhost:7071/api/bulk-delete/Consignors
Content-Type: application/json

[
  { "id": "029c169f-74a2-4288-b9eb-e4241b8aeb7b", "pk": "pk-consignors" },
  { "id": "bbf671b3-b1ed-4340-a006-f5e3bb952789", "pk": "pk-consignors" }
]

###

# 一部存在しない ID を含む
POST http://localhost:7071/api/bulk-delete/Consignors
Content-Type: application/json

[
  { "id": "6e0b379b-5998-4e91-ba20-443e861b5b8a", "pk": "pk-consignors" },
  { "id": "00000000-0000-0000-0000-000000000000", "pk": "pk-consignors" }
]

###

# 400（無効な UUID を含む）
POST http://localhost:7071/api/bulk-delete/Consignors
Content-Type: application/json

[
  { "id": "not-a-uuid", "pk": "pk-consignors" }
]

###

# 400（無効なコンテナ名）
POST http://localhost:7071/api/bulk-delete/Unknown
Content-Type: application/json

[
  { "id": "6e0b379b-5998-4e91-ba20-443e861b5b8a", "pk": "pk-consignors" }
]

###
