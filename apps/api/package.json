{
  "name": "@shisamo/api",
  "version": "0.0.1",
  "description": "Azure Functions API",
  "author": "T.Ichige <magromoe@gmail.com>",
  "type": "module",
  "private": true,
  "main": "dist/src/functions/helloWorld.js",
  "scripts": {
    "build": "node --experimental-strip-types scripts/build.ts",
    "type-check": "tsc --noEmit",
