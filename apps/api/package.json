    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@azure/functions": "^4.7.0"
  },
  "devDependencies": {
    "@shisamo/shared": "workspace:*",
